<?php
// user.php - страница для обычных пользователей
session_start();

// время жизни сессии (5 секунд для теста)
$session_lifetime = 5;

// Проверяем время входа
if (!isset($_SESSION['login_time'])) {
    $_SESSION['login_time'] = time();
}

// Проверяем, не истекла ли сессия
if (time() - $_SESSION['login_time'] > $session_lifetime) {
    $_SESSION = array();
    session_unset();
    session_destroy();
    header('Location: ../login/index.php?expired=1');
    exit();
}

// Проверка авторизации
if (!isset($_SESSION['logged_in']) || $_SESSION['logged_in'] !== true) {
    header('Location: ../login/index.php');
    exit();
}

// Проверка роли
if ($_SESSION['role'] !== 'user') {
    header('Location: ../login/index.php');
    exit();
}

$login_time = $_SESSION['login_time'];
?>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="layout">
        <div class="area">

            <!-- верхний блок -->
            <header class="top-block">
                <div class="top-block-content">
                    <p>Логин: <?php echo htmlspecialchars($_SESSION['login']); ?></p>
                    <button 
                      onclick="confirmLogout()" 
                      style="
                        background-image: url('assets/logout2.svg');
                        background-size: contain;
                        background-repeat: no-repeat;
                        background-position: center;
                        background-color: transparent;
                        width: 40px;
                        height: 40px;
                        border: none;
                        cursor: pointer;
                        text-indent: -9999px;
                        transition: transform 0.2s ease;
                        padding: 0;
                      "
                      onmouseenter="this.style.transform='scale(1.05)'"
                      onmouseleave="this.style.transform='scale(1)'"
                      onmousedown="this.style.transform='scale(0.95)'"
                      onmouseup="this.style.transform='scale(1.05)'"
                    >
                      Выйти
                    </button>
                </div>
            </header>

            <!-- основной контент -->
            <main class="content">

            </main>
        </div>
    </div>
    
    <script>
        let loginTime = <?php echo $login_time; ?>;
        const sessionLifetime = <?php echo $session_lifetime; ?>;
        let timerInterval;

        // Проверка времени
        function checkTime() {
            const now = Math.floor(Date.now() / 1000);
            const timeLeft = sessionLifetime - (now - loginTime);
            
            // Если время вышло - переходим на страницу входа
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                window.location.href = '../login/index.php?expired=1';
                return true;
            }
            return false;
        }

        // Сброс таймера при активности
        function resetTimer() {
            fetch('../auth/reset_session.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    loginTime = data.login_time;
                    // Перезапускаем проверку
                    if (!timerInterval) {
                        timerInterval = setInterval(checkTime, 1000);
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }

        // Проверка сессии на сервере
        function checkSession() {
            fetch('../auth/check_session.php')
                .then(response => response.json())
                .then(data => {
                    if (!data.active) {
                        clearInterval(timerInterval);
                        window.location.href = '../login/index.php?expired=1';
                    } else if (data.login_time) {
                        loginTime = data.login_time;
                    }
                })
                .catch(() => {
                    window.location.href = '../login/index.php?expired=1';
                });
        }

        function handleUserActivity() {
            resetTimer();
        }

        // Отслеживаем активность
        document.addEventListener('click', handleUserActivity);
        document.addEventListener('mousemove', handleUserActivity);
        document.addEventListener('keydown', handleUserActivity);
        document.addEventListener('scroll', handleUserActivity);
        document.addEventListener('touchstart', handleUserActivity);
        document.addEventListener('touchmove', handleUserActivity);
        document.addEventListener('wheel', handleUserActivity);
        document.addEventListener('input', handleUserActivity);

        // Запускаем проверку каждую секунду
        timerInterval = setInterval(checkTime, 1000);
        // Проверяем сессию на сервере каждые 5 секунд
        setInterval(checkSession, 5000);

        function confirmLogout() {
            if (confirm('Вы уверены, что хотите выйти?')) {
                window.location.href = '../auth/logout.php';
            }
        }
    </script>
</body>
</html>